{
  "name": "pi-clinepass-provider",
  "version": "1.0.0",
  "description": "ClinePass provider for pi — access GLM-5.2, Kimi K2.7, DeepSeek V4 and more open-weight coding models through Cline's $9.99/mo subscription",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "clinepass",
    "cline-pass",
    "cline",
    "provider",
    "ai",
    "llm",
    "glm",
    "kimi",
    "deepseek",
    "qwen",
    "minimax",
    "mimo"
  ],
  "author": "jellydn",
  "license": "MIT",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src",
    "tests",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "@earendil-works/pi-ai": ">=0.80 <0.90",
    "@earendil-works/pi-coding-agent": ">=0.80 <0.90"
  },
  "engines": {
    "node": ">=22"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "bash tests/e2e/smoke.sh",
    "lint": "oxlint --config .oxlintrc.json src/ tests/",
    "format": "oxfmt --write src/ tests/",
    "format:check": "oxfmt --check src/ tests/",
    "typecheck": "tsc"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.2",
    "@earendil-works/pi-coding-agent": "^0.80.2",
    "@types/node": "^22.0.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
